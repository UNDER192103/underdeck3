{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",       /* Melhor para ferramentas modernas e ESM */
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true            /* Importante para ler arquivos .json no src */
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "dist"]
}