{
  "name": "underdeck",
  "description": "UnderDeck Application",
  "productName": "Under Deck",
  "version": "3.0.18",
  "main": "dist/main/main.js",
  "type": "module",
  "author": "Under",
  "license": "MIT",
  "underdeck": {
    "github": {
      "owner": "UNDER192103",
      "repo": "underdeck3"
    }
  },
  "scripts": {
    "start": "set NODE_OPTIONS=--import tsx && electron src/main/main.ts",
    "nodemon": "nodemon --watch src --ext ts --exec \"cls && npm start\" --delay 1",
    "clean": "rimraf dist build",
    "compile": "tsc",
    "build:prepare": "npm run clean && npm --prefix ..\\client run build && npm run compile",
    "build:unpacked": "npm run build:prepare && dotenv -e .env -- electron-builder --dir",
    "build:velopack": "npm run build:prepare && dotenv -e .env -- .\\build-velopack.bat",
    "rebuild:native": "electron-rebuild -f -w robotjs,better-sqlite3",
    "postinstall": "electron-rebuild",
    "dist": "npm run build:velopack",
    "dist:publish": "npm run build:velopack",
    "dist:prod": "npm run build:velopack"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.14.1",
    "@types/qrcode": "^1.5.6",
    "auto-launch": "^5.0.6",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "call-bind-apply-helpers": "^1.0.2",
    "cli-color": "^2.0.4",
    "cross-fetch": "^4.1.0",
    "decompress": "^4.2.1",
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.3.1",
    "electron-cookies": "^1.1.0",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "obs-websocket-js": "^5.0.7",
    "open": "^11.0.0",
    "qrcode": "^1.5.4",
    "robotjs": "^0.6.0",
    "socket.io": "^4.8.3",
    "uiohook-napi": "^1.5.4",
    "velopack": "^0.0.1444-gc245055",
    "ws": "^8.19.0",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cli-color": "^2.0.6",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "node-gyp": "^12.2.0",
    "nodemon": "^3.1.14",
    "prebuild-install": "^7.1.3",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "yauzl": "^3.2.1",
    "tar": "^6.2.1",
    "@tootallnate/once": "^3.0.1"
  }
}
